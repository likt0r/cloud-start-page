# Keycloak OIDC
NUXT_OIDC_PROVIDERS_KEYCLOAK_BASE_URL=https://keycloak.example.com/realms/myrealm
NUXT_OIDC_PROVIDERS_KEYCLOAK_CLIENT_ID=cloud-start-page
NUXT_OIDC_PROVIDERS_KEYCLOAK_CLIENT_SECRET=your-client-secret
NUXT_OIDC_PROVIDERS_KEYCLOAK_REDIRECT_URI=https://app.example.com/auth/keycloak/callback
NUXT_OIDC_PROVIDERS_KEYCLOAK_LOGOUT_REDIRECT_URI=https://app.example.com/
# Session encryption (generate with: openssl rand -base64 48)
NUXT_OIDC_SESSION_SECRET=
NUXT_OIDC_AUTH_SESSION_SECRET=
# AES key in base64 (generate with: openssl rand -base64 32)
NUXT_OIDC_TOKEN_KEY=

# Admin group name from Keycloak
NUXT_ADMIN_GROUP=cloud-admins

# SQLite database path (default: .data/db.sqlite)
NUXT_DB_PATH=

# Upload directory for service logos (default: .data/uploads)
# In Docker: set to an absolute path and mount a volume there
NUXT_UPLOAD_DIR=
