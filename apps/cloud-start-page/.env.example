# Keycloak OIDC
NUXT_OIDC_PROVIDERS_KEYCLOAK_BASE_URL=https://keycloak.example.com/realms/myrealm
NUXT_OIDC_PROVIDERS_KEYCLOAK_CLIENT_ID=cloud-start-page
NUXT_OIDC_PROVIDERS_KEYCLOAK_CLIENT_SECRET=your-client-secret
NUXT_OIDC_PROVIDERS_KEYCLOAK_REDIRECT_URI=https://app.example.com/auth/keycloak/callback
NUXT_OIDC_PROVIDERS_KEYCLOAK_LOGOUT_REDIRECT_URI=https://app.example.com/

# --- OIDC secrets (required in production; see nuxt.config oidc.provideDefaultSecrets) ---
# NUXT_OIDC_SESSION_SECRET: encrypts the logged-in user cookie ("nuxt-oidc-auth").
# NUXT_OIDC_AUTH_SESSION_SECRET: encrypts the short-lived PKCE cookie ("oidc") during login.
#   If this value changes between /auth/.../login and /auth/.../callback, Keycloak returns:
#   invalid_grant: PKCE code verifier not specified. Set explicit values for every deploy/replica.
# NUXT_OIDC_TOKEN_KEY: encrypts refresh/access/id tokens in Nitro storage.
# Session encryption (generate with: openssl rand -base64 48)
NUXT_OIDC_SESSION_SECRET=RANDOM_BASE64_STRING
NUXT_OIDC_AUTH_SESSION_SECRET=RANDOM_BASE64_STRING
# AES key in base64 (generate with: openssl rand -base64 32)
NUXT_OIDC_TOKEN_KEY=RANDOM_BASE64_STRING

# Optional: set to true for full JWKS validation of access tokens (requires OS time in sync with Keycloak).
# If login fails with JWTExpired / exp, leave unset or false and fix NTP before enabling.
# NUXT_OIDC_VALIDATE_ACCESS_TOKEN=true

# Troubleshooting:
# - Use one host only in dev: match Keycloak "Valid redirect URIs", NUXT_OIDC_*_REDIRECT_URI, and the URL
#   you open in the browser (localhost vs 127.0.0.1 are different sites for cookies).
# - JWTExpired / exp: sync OS time (NTP). Behind a reverse proxy, ensure forwarded HTTPS/proto is correct.

# Admin group name from Keycloak
NUXT_ADMIN_GROUP=cloud-admins

# SQLite database path (default: .data/db.sqlite)
NUXT_DB_PATH=.data/db.sqlite

# Upload directory for service logos (default: .data/uploads)
# In Docker: set to an absolute path and mount a volume there
NUXT_UPLOAD_DIR=.data/uploads
NUXT_OIDC_PROVIDERS_KEYCLOAK_AUTHORIZATION_URL=https://keycloak.example.com/realms/apollon/protocol/openid-connect/auth
NUXT_OIDC_PROVIDERS_KEYCLOAK_TOKEN_URL=https://keycloak.example.com/realms/apollon/protocol/openid-connect/token
NUXT_OIDC_PROVIDERS_KEYCLOAK_USER_INFO_URL=https://keycloak.example.com/realms/apollon/protocol/openid-connect/userinfo
NUXT_OIDC_PROVIDERS_KEYCLOAK_LOGOUT_URL=https://keycloak.example.com/realms/apollon/protocol/openid-connect/logout