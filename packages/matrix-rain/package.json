{
  "name": "matrix-rain",
  "version": "0.1.0",
  "description": "Matrix-style canvas rain effect for vanilla JavaScript",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./browser": "./dist/index.global.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npx tsup src/index.ts --format esm,cjs,iife --globalName MatrixRain --dts --clean",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
