{
  "name": "cloud-start-page-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w cloud-start-page",
    "build": "npm run build -w cloud-start-page",
    "preview": "npm run preview -w cloud-start-page",
    "lint": "npm run lint -w cloud-start-page",
    "typecheck": "npm run typecheck -w cloud-start-page",
    "db:generate": "npm run db:generate -w cloud-start-page",
    "db:migrate": "npm run db:migrate -w cloud-start-page",
    "keycloak:dev": "npm run dev -w mean-roboto-keycloak",
    "keycloak:build": "npm run build-keycloak-theme -w mean-roboto-keycloak",
    "keycloak:release": "npm run release -w mean-roboto-keycloak",
    "keycloak:storybook": "npm run storybook -w mean-roboto-keycloak",
    "matrix-rain:build": "npm run build -w matrix-rain",
    "release": "release-it"
  },
  "devDependencies": {
    "release-it": "^19.2.4"
  },
  "version": "1.1.0"
}
